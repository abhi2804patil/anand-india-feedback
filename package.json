{
  "name": "anand-india-feedback",
  "version": "1.0.0",
  "private": true,
  "description": "Anand India Business Hub — Tenant Feedback System",
  "workspaces": ["server", "client"],
  "scripts": {
    "install:all": "npm install && npm install --workspace server && npm install --workspace client",
    "seed": "npm run seed --workspace server",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
